# Copy this file to `.env` and fill values. Never commit `.env`.
# On Hugging Face Spaces, set these as Space "Secrets" instead.

# Mailtrap (form delivery)
SMTP_SERVER=live.smtp.mailtrap.io
SMTP_PORT=587
SMTP_USERNAME=api
SMTP_PASSWORD=

# Gmail (auto-reply via app password)
GOOGLE_SMTP_SERVER=smtp.gmail.com
GOOGLE_SMTP_PORT=587
GOOGLE_SMTP_USERNAME=
GOOGLE_SMTP_PASSWORD=

# Form recipient
CONTACT_RECEIVER_EMAIL=
CONTACT_SENDER_DISPLAY=Private Person <mailtrap@demomailtrap.com>

# Data
DATA_DIR=data

# Analytics
GA_TRACKING_ID=G-CPK41EM5P3
